# Environment Configuration
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1

# Model Configuration
MODEL_PATH=models/indian_plate_detector.pt
MODEL_CONFIDENCE_THRESHOLD=0.25

# Processing Configuration
MAX_IMAGE_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# OCR Configuration
USE_EASYOCR=true
USE_PADDLEOCR=false
USE_TESSERACT=false

# Features
ENABLE_ANALYTICS=true
ENABLE_FEEDBACK=true